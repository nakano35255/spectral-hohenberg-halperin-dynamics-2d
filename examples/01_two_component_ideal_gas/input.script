# ==========================================================
# Example 01: 2成分・等温 FHD
# ==========================================================
#
# これは 2D ソルバーで採用したい input.script の案です。
# parser と solver は、このような LAMMPS 風の入力を読めるように
# 開発していきます。

# ----------------------------------------------------------
# 1. 系の設定
# ----------------------------------------------------------

dimension       2
components      2
boundary        p p

grid            128 128
length          128.0 128.0

# ----------------------------------------------------------
# 2. 時間積分
# ----------------------------------------------------------

integrator      euler
timestep        1.0e-3

# ----------------------------------------------------------
# 3. 数式で使うスカラー変数
# ----------------------------------------------------------

variable        kB       const 1.0
variable        T        const 1.0

variable        m0       const 1.0
variable        m1       const 1.0
variable        rho00    const 1.0
variable        rho10    const 1.0

variable        D        const 0.1
variable        eta0     const 1.0
variable        zeta0    const 1.0
variable        zeta1    const 0.0
variable        a_eta    const 0.0
variable        rho_ref  const 2.0

# ----------------------------------------------------------
# 4. 熱力学
# ----------------------------------------------------------
#
# 自由エネルギー密度を文字列の数式として与えます。
# 実装側では、ここから化学ポテンシャルと圧力を
#
#   mu_k = d f / d rho_k
#   p    = -f + sum_k rho_k mu_k
#
# として導出します。
# rho0, rho1 は各成分密度、rho は全密度 rho0 + rho1 を表します。

free_energy     expr kB*T*(rho0/m0*(log(rho0/rho00)-1) + rho1/m1*(log(rho1/rho10)-1))

# ----------------------------------------------------------
# 5. 移動度行列
# ----------------------------------------------------------
#
# L_coeff の各成分を密度依存の数式として与えます。
# solver は各格子点で L 行列を評価した後、
#
#   L_ij = L_ji
#   sum_i L_ij = 0
#   L が半正定値
#
# を確認してから、確率的質量フラックスの生成に用います。

variable        lambda   expr D*m0*m1*rho0*rho1/(kB*T*(m0*rho1 + m1*rho0))

L_coeff         0 0      expr lambda
L_coeff         0 1      expr -lambda
L_coeff         1 0      expr -lambda
L_coeff         1 1      expr lambda

# ----------------------------------------------------------
# 6. 粘性
# ----------------------------------------------------------
#
# eta と zeta も局所密度に依存する数式として与えられます。

eta             expr eta0 * exp(a_eta * (rho - rho_ref))
zeta            expr zeta0 + zeta1 * rho

# ----------------------------------------------------------
# 7. 確率項
# ----------------------------------------------------------

fix             1 all noise on seed 12345
fix             2 all barodiffusion off

# ----------------------------------------------------------
# 8. 初期条件
# ----------------------------------------------------------

set             density 0 uniform value 1.0
set             density 1 uniform value 1.0
set             momentum all uniform value 0.0

# ----------------------------------------------------------
# 9. 出力
# ----------------------------------------------------------

thermo          observe on progress on nevery 1000
# measure         1 snapshot on Nevery 1000 file outputs/snapshot
restart         off

# ----------------------------------------------------------
# 10. 時間発展
# ----------------------------------------------------------

run             10000

fix             1 all noise off

run             10000
